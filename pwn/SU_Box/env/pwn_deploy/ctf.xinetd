service ctf
{
    disable = no
    socket_type = stream
    protocol    = tcp
    wait        = no
    user        = root
    type        = UNLISTED
    port        = 10008
    bind        = 0.0.0.0
    server      = /app/run.sh
    banner_fail = /etc/banner_fail
    per_source  = 10
    rlimit_cpu  = 60
}
